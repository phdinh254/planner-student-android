<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="28dp"
    android:paddingEnd="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="L&#7883;ch"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTodayCalendar"
            style="@style/Widget.PersonalPlanner.Button.Outlined"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:minHeight="38dp"
            android:minWidth="0dp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:text="H&#244;m nay"
            android:textAllCaps="false"
            android:textColor="@color/primary"
            app:strokeColor="@color/primary" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:layout_marginTop="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnPrevMonth"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="&#8249;"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtMonthTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnNextMonth"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="&#8250;"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />
    </LinearLayout>

    <GridLayout
        android:id="@+id/gridWeekdays"
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:columnCount="7">

        <TextView style="@style/Widget.PersonalPlanner.CalendarWeekday" android:text="CN" />
        <TextView style="@style/Widget.PersonalPlanner.CalendarWeekday" android:text="T2" />
        <TextView style="@style/Widget.PersonalPlanner.CalendarWeekday" android:text="T3" />
        <TextView style="@style/Widget.PersonalPlanner.CalendarWeekday" android:text="T4" />
        <TextView style="@style/Widget.PersonalPlanner.CalendarWeekday" android:text="T5" />
        <TextView style="@style/Widget.PersonalPlanner.CalendarWeekday" android:text="T6" />
        <TextView style="@style/Widget.PersonalPlanner.CalendarWeekday" android:text="T7" />
    </GridLayout>

    <GridLayout
        android:id="@+id/gridCalendarDays"
        android:layout_width="match_parent"
        android:layout_height="218dp"
        android:columnCount="7"
        android:rowCount="6" />

    <TextView
        android:id="@+id/txtSelectedDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtCalendarEmpty"
        android:layout_width="match_parent"
        android:layout_height="78dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_empty_state"
        android:gravity="center"
        android:padding="18dp"
        android:text="@string/empty_calendar"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerCalendarTasks"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="2dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="22dp" />
</LinearLayout>
