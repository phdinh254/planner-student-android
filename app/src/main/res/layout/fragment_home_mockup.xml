<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="28dp"
        android:paddingEnd="20dp"
        android:paddingBottom="26dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ch&#224;o m&#7915;ng tr&#7903; l&#7841;i"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtUserName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/text_primary"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnAvatar"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="@drawable/bg_stat_primary"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center"
                android:text="AN"
                android:textColor="@color/primary_dark"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:columnCount="2"
            android:rowCount="2">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="82dp"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                android:background="@drawable/bg_stat_primary"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="13dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="T&#7893;ng k&#7871; ho&#7841;ch"
                    android:textColor="@color/primary_dark"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtTotalPlans"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:textColor="@color/primary_dark"
                    android:textSize="24sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="82dp"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                android:background="@drawable/bg_stat_warning"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="13dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="&#272;ang th&#7921;c hi&#7879;n"
                    android:textColor="@color/warning"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtInProgress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:textColor="@color/warning"
                    android:textSize="24sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="82dp"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                android:background="@drawable/bg_stat_success"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="13dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="&#272;&#227; ho&#224;n th&#224;nh"
                    android:textColor="@color/success"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtCompleted"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:textColor="@color/success"
                    android:textSize="24sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="82dp"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                android:background="@drawable/bg_stat_danger"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="13dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Qu&#225; h&#7841;n"
                    android:textColor="@color/danger"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtOverdue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:textColor="@color/danger"
                    android:textSize="24sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </GridLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="K&#7871; ho&#7841;ch h&#244;m nay"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewAllPlans"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:minWidth="0dp"
                android:text="Xem t&#7845;t c&#7843;"
                android:textAllCaps="false"
                android:textColor="@color/primary" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtEmptyPlans"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_empty_state"
            android:gravity="center"
            android:padding="18dp"
            android:text="H&#244;m nay ch&#432;a c&#243; k&#7871; ho&#7841;ch n&#224;o. Nh&#7845;n + &#273;&#7875; th&#234;m vi&#7879;c m&#7899;i."
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:visibility="gone" />

        <include
            android:id="@+id/rowPlanToday1"
            layout="@layout/item_home_plan_mockup" />

        <include
            android:id="@+id/rowPlanToday2"
            layout="@layout/item_home_plan_mockup" />

        <include
            android:id="@+id/rowPlanToday3"
            layout="@layout/item_home_plan_mockup" />
    </LinearLayout>
</ScrollView>
