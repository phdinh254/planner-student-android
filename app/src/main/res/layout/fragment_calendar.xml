<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="28dp"
    android:paddingEnd="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/calendar_title"
            android:textAppearance="@style/TextAppearance.PersonalPlanner.Headline" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTodayCalendar"
            style="@style/Widget.PersonalPlanner.Button.Outlined"
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:minHeight="42dp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:text="H&#244;m nay" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/calendar_subtitle"
        android:textAppearance="@style/TextAppearance.PersonalPlanner.Body" />

    <com.google.android.material.card.MaterialCardView
        style="@style/Widget.PersonalPlanner.Card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp">
        <CalendarView
            android:id="@+id/calendarView"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:firstDayOfWeek="2"
            android:focusedMonthDateColor="@color/text_primary"
            android:selectedWeekBackgroundColor="@color/primary_container"
            android:weekSeparatorLineColor="@color/outline" />
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroupCalendarMode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:selectionRequired="true"
        app:singleSelection="true">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipModeDay"
            style="@style/Widget.MaterialComponents.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="@string/calendar_mode_day" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipModeWeek"
            style="@style/Widget.MaterialComponents.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/calendar_mode_week" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipModeMonth"
            style="@style/Widget.MaterialComponents.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/calendar_mode_month" />
    </com.google.android.material.chip.ChipGroup>

    <TextView
        android:id="@+id/txtSelectedDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:textAppearance="@style/TextAppearance.PersonalPlanner.Title" />

    <TextView
        android:id="@+id/txtCalendarEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_empty_state"
        android:gravity="center"
        android:padding="24dp"
        android:text="@string/empty_calendar"
        android:textAppearance="@style/TextAppearance.PersonalPlanner.Body"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerCalendarTasks"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="6dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="20dp" />

    <TextView
        android:id="@+id/txtUpcomingTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/upcoming_plans"
        android:textAppearance="@style/TextAppearance.PersonalPlanner.Title" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerUpcomingTasks"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="6dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="20dp" />
</LinearLayout>
