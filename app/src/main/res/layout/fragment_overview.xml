<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="28dp"
        android:paddingEnd="20dp"
        android:paddingBottom="30dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="T&#7893;ng quan"
                android:textAppearance="@style/TextAppearance.PersonalPlanner.Headline" />

            <ImageButton
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Export"
                android:padding="9dp"
                android:src="@drawable/ic_tasks"
                app:tint="@color/text_primary" />
        </LinearLayout>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:columnCount="2">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="92dp"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                android:background="@drawable/bg_soft_field"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="T&#7893;ng s&#7889; k&#7871; ho&#7841;ch"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtOverviewTotal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/text_primary"
                    android:textSize="26sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="92dp"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                android:background="@drawable/bg_stat_primary"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="&#272;ang th&#7921;c hi&#7879;n"
                    android:textColor="@color/primary_dark"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtOverviewPending"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/primary_dark"
                    android:textSize="26sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="92dp"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                android:background="@drawable/bg_stat_success"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="&#272;&#227; ho&#224;n th&#224;nh"
                    android:textColor="@color/success"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtOverviewCompleted"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/success"
                    android:textSize="26sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="92dp"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                android:background="@drawable/bg_stat_danger"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Qu&#225; h&#7841;n"
                    android:textColor="@color/danger"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtOverviewOverdue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/danger"
                    android:textSize="26sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </GridLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Ti&#7871;n &#273;&#7897; ho&#224;n th&#224;nh"
            android:textAppearance="@style/TextAppearance.PersonalPlanner.Title" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.PersonalPlanner.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="132dp"
                    android:baselineAligned="false"
                    android:gravity="bottom"
                    android:orientation="horizontal"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp">

                    <View android:layout_width="0dp" android:layout_height="46dp" android:layout_margin="7dp" android:layout_weight="1" android:background="@color/teal" />
                    <View android:layout_width="0dp" android:layout_height="82dp" android:layout_margin="7dp" android:layout_weight="1" android:background="@color/teal" />
                    <View android:layout_width="0dp" android:layout_height="60dp" android:layout_margin="7dp" android:layout_weight="1" android:background="@color/teal" />
                    <View android:layout_width="0dp" android:layout_height="112dp" android:layout_margin="7dp" android:layout_weight="1" android:background="@color/teal" />
                    <View android:layout_width="0dp" android:layout_height="88dp" android:layout_margin="7dp" android:layout_weight="1" android:background="@color/teal" />
                    <View android:layout_width="0dp" android:layout_height="14dp" android:layout_margin="7dp" android:layout_weight="1" android:background="@color/outline" />
                    <View android:layout_width="0dp" android:layout_height="48dp" android:layout_margin="7dp" android:layout_weight="1" android:background="@color/teal" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="T2" android:textColor="@color/text_secondary" android:textSize="11sp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="T3" android:textColor="@color/text_secondary" android:textSize="11sp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="T4" android:textColor="@color/text_secondary" android:textSize="11sp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="T5" android:textColor="@color/text_secondary" android:textSize="11sp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="T6" android:textColor="@color/text_secondary" android:textSize="11sp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="T7" android:textColor="@color/text_secondary" android:textSize="11sp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="CN" android:textColor="@color/text_secondary" android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.PersonalPlanner.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="@color/surface_variant">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="18dp">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/progressOverviewCompletion"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:progress="0"
                    app:indicatorColor="@color/teal"
                    app:indicatorSize="72dp"
                    app:trackColor="@color/outline"
                    app:trackThickness="7dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="18dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtOverviewCompletion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtOverviewRange"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:lineSpacingExtra="2dp"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Theo m&#7913;c &#432;u ti&#234;n"
            android:textAppearance="@style/TextAppearance.PersonalPlanner.Title" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_soft_field"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/txtPriorityHigh"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />
            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progressPriorityHigh"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginTop="5dp"
                app:indicatorColor="@color/danger"
                app:trackColor="@color/outline"
                app:trackCornerRadius="3dp"
                app:trackThickness="6dp" />

            <TextView
                android:id="@+id/txtPriorityMedium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />
            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progressPriorityMedium"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginTop="5dp"
                app:indicatorColor="@color/warning"
                app:trackColor="@color/outline"
                app:trackCornerRadius="3dp"
                app:trackThickness="6dp" />

            <TextView
                android:id="@+id/txtPriorityLow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />
            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progressPriorityLow"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginTop="5dp"
                app:indicatorColor="@color/text_secondary"
                app:trackColor="@color/outline"
                app:trackCornerRadius="3dp"
                app:trackThickness="6dp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="S&#7855;p &#273;&#7871;n h&#7841;n"
            android:textAppearance="@style/TextAppearance.PersonalPlanner.Title" />

        <TextView
            android:id="@+id/txtDueSoon"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_soft_field"
            android:padding="16dp"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="L&#7883;ch h&#244;m nay"
            android:textAppearance="@style/TextAppearance.PersonalPlanner.Title" />

        <TextView
            android:id="@+id/txtTodayPlan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_soft_field"
            android:padding="16dp"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>
</ScrollView>
