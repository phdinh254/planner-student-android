<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="22dp"
        android:paddingEnd="20dp"
        android:paddingBottom="28dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Space
                android:layout_width="44dp"
                android:layout_height="44dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="L&#7883;ch m&#7899;i"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Space
                android:layout_width="44dp"
                android:layout_height="44dp" />
        </LinearLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.PersonalPlanner.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:hint="Ti&#234;u &#273;&#7873;">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edtTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapSentences"
                android:maxLines="2" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchAllDay"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:text="24H / C&#7843; ng&#224;y"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnChooseDate"
            style="@style/Widget.PersonalPlanner.Button.SoftField"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textAllCaps="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnChooseTime"
            style="@style/Widget.PersonalPlanner.Button.SoftField"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textAllCaps="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnChooseEndTime"
            style="@style/Widget.PersonalPlanner.Button.SoftField"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textAllCaps="false" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Gi&#7901; t&#7921; &#273;&#7863;t 00:00 - 23:59 khi b&#7853;t c&#7843; ng&#224;y"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/txtConflictWarning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_stat_warning"
            android:lineSpacingExtra="2dp"
            android:padding="14dp"
            android:text="@string/schedule_conflict_warning"
            android:textColor="@color/warning"
            android:textSize="13sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            style="@style/Widget.PersonalPlanner.SettingsSectionLabel"
            android:text="L&#7863;p l&#7841;i" />

        <Spinner
            android:id="@+id/spinnerRepeatRule"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_soft_field"
            android:paddingHorizontal="12dp" />

        <TextView
            style="@style/Widget.PersonalPlanner.SettingsSectionLabel"
            android:text="Thu&#7897;c k&#7871; ho&#7841;ch" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            app:selectionRequired="true"
            app:singleLine="false"
            app:singleSelection="true" />

        <Spinner
            android:id="@+id/spinnerCategory"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:visibility="invisible" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnManageCategories"
            style="@style/Widget.PersonalPlanner.Button.Outlined"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="8dp"
            android:minHeight="46dp"
            android:text="@string/manage_courses"
            android:visibility="gone" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.PersonalPlanner.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Ghi ch&#250;">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edtDescription"
                android:layout_width="match_parent"
                android:layout_height="116dp"
                android:gravity="top"
                android:inputType="textCapSentences|textMultiLine"
                android:maxLength="500" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            style="@style/Widget.PersonalPlanner.SettingsSectionLabel"
            android:text="@string/priority" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupPriority"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            app:selectionRequired="true"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipPriorityLow"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Th&#7845;p" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipPriorityMedium"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Trung b&#236;nh" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipPriorityHigh"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cao" />
        </com.google.android.material.chip.ChipGroup>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/priority_help"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <TextView
            style="@style/Widget.PersonalPlanner.SettingsSectionLabel"
            android:text="Nh&#7855;c nh&#7903;" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchReminder"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/enable_reminder"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/spinnerReminderLead"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_soft_field"
            android:paddingHorizontal="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveTask"
            style="@style/Widget.PersonalPlanner.Button"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="18dp"
            android:text="@string/save_schedule" />

        <Spinner
            android:id="@+id/spinnerPlanType"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:visibility="invisible" />

        <Spinner
            android:id="@+id/spinnerPriority"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:visibility="invisible" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutLocation"
            style="@style/Widget.PersonalPlanner.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edtLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutRoom"
            style="@style/Widget.PersonalPlanner.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edtRoom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutSubject"
            style="@style/Widget.PersonalPlanner.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edtSubject"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutWage"
            style="@style/Widget.PersonalPlanner.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edtWage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.PersonalPlanner.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edtRepeatUntil"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.PersonalPlanner.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edtDuration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:text="@string/default_duration" />
        </com.google.android.material.textfield.TextInputLayout>

        <CheckBox
            android:id="@+id/chkSubmitted"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:visibility="invisible" />
    </LinearLayout>
</ScrollView>
