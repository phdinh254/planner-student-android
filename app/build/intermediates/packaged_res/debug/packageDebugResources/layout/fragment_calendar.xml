<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="28dp"
    android:paddingEnd="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/calendar_title"
        android:textAppearance="@style/TextAppearance.PersonalPlanner.Headline" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/calendar_subtitle"
        android:textAppearance="@style/TextAppearance.PersonalPlanner.Body" />

    <com.google.android.material.card.MaterialCardView
        style="@style/Widget.PersonalPlanner.Card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp">
        <CalendarView
            android:id="@+id/calendarView"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:firstDayOfWeek="2"
            android:focusedMonthDateColor="@color/text_primary"
            android:selectedWeekBackgroundColor="@color/primary_container"
            android:weekSeparatorLineColor="@color/outline" />
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/txtSelectedDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:textAppearance="@style/TextAppearance.PersonalPlanner.Title" />

    <TextView
        android:id="@+id/txtCalendarEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="24dp"
        android:text="@string/empty_calendar"
        android:textAppearance="@style/TextAppearance.PersonalPlanner.Body"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerCalendarTasks"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="6dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="20dp" />
</LinearLayout>
